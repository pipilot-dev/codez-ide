{
  "name": "codez-ide",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Codez — a browser-based VSCode-style IDE built on OpenSumi codeblitz.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit"
